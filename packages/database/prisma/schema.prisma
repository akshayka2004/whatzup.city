// ============================================================
// Prisma Schema — Enterprise SaaS Platform
// Multi-tenant architecture with tenant_id isolation
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── TENANTS ─────────────────────────────────────────────────

model Tenant {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  slug      String    @unique @db.VarChar(255)
  domain    String?   @db.VarChar(255)
  logo      String?   @db.Text
  settings  Json?
  isActive  Boolean   @default(true) @map("is_active")
  
  // Core Audit Fields
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  // Relations
  users                   User[]
  roles                   Role[]
  permissions             Permission[]
  userRoles               UserRole[]
  rolePermissions         RolePermission[]
  sessions                Session[]
  refreshTokens           RefreshToken[]
  deviceLogins            DeviceLogin[]
  businesses              Business[]
  businessBranches        BusinessBranch[]
  categories              Category[]
  businessDocuments       BusinessDocument[]
  businessStaff           BusinessStaff[]
  businessVerifications   BusinessVerification[]
  productCategories       ProductCategory[]
  products                Product[]
  offers                  Offer[]
  offerRedemptions        OfferRedemption[]
  events                  Event[]
  eventClicks             EventClick[]
  coupons                 Coupon[]
  reviews                 Review[]
  reviewMedia             ReviewMedia[]
  reviewVotes             ReviewVote[]
  bookmarks               Bookmark[]
  favorites               Favorite[]
  userFollows             UserFollow[]
  bills                   Bill[]
  billItems               BillItem[]
  billVerifications       BillVerification[]
  verifiedPurchases       VerifiedPurchase[]
  notifications           Notification[]
  notificationRecipients  NotificationRecipient[]
  notificationPreferences NotificationPreference[]
  announcements           GovernmentAnnouncement[]
  media                   Media[]
  analyticsEvents         AnalyticsEvent[]
  businessMetrics         BusinessMetric[]
  userActivities          UserActivity[]
  searchHistories         SearchHistory[]
  moderationReports       ModerationReport[]
  auditLogs               AuditLog[]
  adminActions            AdminAction[]
  fraudFlags              FraudFlag[]
  featureFlags            FeatureFlag[]
  customers               Customer[]
  subscriptions           Subscription[]
  payments                Payment[]
  onboardingProgress      OnboardingProgress[]
  onboardingEvents        OnboardingEvent[]
  entities                Entity[]
  uploadedDocuments       UploadedDocument[]
  verificationRequests    VerificationRequest[]
  plans                   Plan[]
  businessTags            BusinessTag[]
  businessCustomers       BusinessCustomer[]

  @@index([deletedAt])
  @@map("tenants")
}

// ── USERS & AUTHENTICATION ──────────────────────────────────

model User {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  email         String       @db.VarChar(255)
  passwordHash  String       @map("password_hash") @db.Text
  name          String       @db.VarChar(255)
  phone         String?      @db.VarChar(50)
  avatar        String?      @db.Text
  role          UserRoleEnum @default(USER)
  isActive      Boolean      @default(true) @map("is_active")
  emailVerified Boolean      @default(false) @map("email_verified")
  lastLoginAt   DateTime?    @map("last_login_at")
  referralCode         String?      @unique @map("referral_code") @db.VarChar(20)
  referredBy           String?      @map("referred_by") @db.Uuid
  acceptedTermsAt      DateTime?    @map("accepted_terms_at")
  acceptedPrivacyAt    DateTime?    @map("accepted_privacy_at")
  termsVersion         String?      @map("terms_version") @db.VarChar(20)
  privacyPolicyVersion String?      @map("privacy_policy_version") @db.VarChar(20)

  // Core Audit Fields
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")
  createdBy     String?      @map("created_by") @db.Uuid
  updatedBy     String?      @map("updated_by") @db.Uuid

  // Relations
  tenant                 Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles              UserRole[]
  sessions               Session[]
  refreshTokens          RefreshToken[]
  deviceLogins           DeviceLogin[]
  businesses             Business[]               @relation("BusinessOwner")
  businessStaff          BusinessStaff[]
  offerRedemptions       OfferRedemption[]
  reviews                Review[]
  reviewVotes            ReviewVote[]
  bookmarks              Bookmark[]
  favorites              Favorite[]
  followsAsFollower      UserFollow[]             @relation("UserFollower")
  followsAsFollowing     UserFollow[]             @relation("UserFollowing")
  billsUploaded          Bill[]                   @relation("BillUploader")
  billsVerified          Bill[]                   @relation("BillVerifier")
  billVerifications      BillVerification[]
  verifiedPurchases      VerifiedPurchase[]
  notifications          Notification[]
  notificationRecipients NotificationRecipient[]
  notificationPreferences NotificationPreference[]
  userActivities         UserActivity[]
  searchHistories        SearchHistory[]
  moderationReports      ModerationReport[]       @relation("ReportAuthor")
  resolvedReports        ModerationReport[]       @relation("ReportResolver")
  adminActions           AdminAction[]
  resolvedFrauds         FraudFlag[]
  auditLogs              AuditLog[]
  businessVerifications  BusinessVerification[]
  customerProfile        Customer?
  entities               Entity[]
  entityVerifications    VerificationRequest[]    @relation("EntityVerifier")
  businessRelationships  BusinessCustomer[]       @relation("UserBusinessRelationships")


  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([role])
  @@index([deletedAt])
  @@index([referralCode])    // fast lookup when user registers with a code
  @@index([referredBy])      // leaderboard GROUP BY referredBy
  @@map("users")
}

model Customer {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  userId        String         @unique @map("user_id") @db.Uuid
  firstName     String         @map("first_name") @db.VarChar(100)
  lastName      String         @map("last_name") @db.VarChar(100)
  email         String         @db.VarChar(255)
  phone         String?        @db.VarChar(50)
  phoneVerified Boolean        @default(false) @map("phone_verified")
  avatar        String?        @db.Text
  city          String?        @db.VarChar(100)
  district      String?        @db.VarChar(100)
  state         String?        @db.VarChar(100)
  preferences   Json           @default("{}")
  status        CustomerStatus @default(PENDING)

  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")
  createdBy     String?        @map("created_by") @db.Uuid
  updatedBy     String?        @map("updated_by") @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId, status])
  @@index([tenantId, city, state])
  @@index([deletedAt])
  @@map("customers")
}

enum CustomerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum UserRoleEnum {
  USER
  BUSINESS_OWNER
  BUSINESS_MODERATOR
  BUSINESS_STAFF
  MASTER_ADMIN
  SUPER_ADMIN
  GOVERNMENT_ADMIN
  INFLUENCER
  PROFESSIONAL
  EVENT_ORGANIZER
  ORGANIZATION_ADMIN
  NGO_ADMIN
  COMMUNITY_ADMIN
  NEWS_FORUM_ADMIN
  // Legacy value kept for migration compatibility
  BUSINESS_ADMIN
}

enum BusinessMemberRole {
  OWNER
  MODERATOR
  STAFF
}

enum EntityType {
  CUSTOMER
  BUSINESS
  INFLUENCER
  PROFESSIONAL
  EVENT_ORGANIZER
  ORGANIZATION
  GOVERNMENT
  NGO
  COMMUNITY
  NEWS_FORUM
}

enum EntityStatus {
  DRAFT
  PENDING_VERIFICATION
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}


// ── RBAC MODELS ─────────────────────────────────────────────

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  code        String    @db.VarChar(50)
  name        String    @db.VarChar(100)
  description String?   @db.Text
  
  // Core Audit Fields
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  // Relations
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(100)
  description String?   @db.Text
  resource    String    @db.VarChar(100)
  action      String    @db.VarChar(50)
  
  // Core Audit Fields
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  // Relations
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@unique([tenantId, resource, action])
  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([deletedAt])
  @@map("permissions")
}

model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  
  // Core Audit Fields
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, roleId])
  @@index([tenantId])
  @@index([userId])
  @@index([roleId])
  @@index([deletedAt])
  @@map("user_roles")
}

model RolePermission {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  roleId       String    @map("role_id") @db.Uuid
  permissionId String    @map("permission_id") @db.Uuid
  
  // Core Audit Fields
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, roleId, permissionId])
  @@index([tenantId])
  @@index([roleId])
  @@index([permissionId])
  @@index([deletedAt])
  @@map("role_permissions")
}

// ── SESSIONS & DEVICES ──────────────────────────────────────

model Session {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  refreshToken String    @unique @map("refresh_token") @db.Text
  userAgent    String?   @map("user_agent") @db.Text
  ipAddress    String?   @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime  @map("expires_at")
  
  // Core Audit Fields
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@index([deletedAt])
  @@map("sessions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.Text
  isRevoked Boolean   @default(false) @map("is_revoked")
  expiresAt DateTime  @map("expires_at")
  
  // Core Audit Fields
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([token])
  @@index([deletedAt])
  @@map("refresh_tokens")
}

model DeviceLogin {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  deviceType  String    @map("device_type") @db.VarChar(100)
  deviceToken String?   @map("device_token") @db.Text
  os          String?   @db.VarChar(50)
  browser     String?   @db.VarChar(50)
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  lastLoginAt DateTime  @default(now()) @map("last_login_at")
  
  // Core Audit Fields
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([deletedAt])
  @@map("device_logins")
}

// ── BUSINESS MODULE ─────────────────────────────────────────

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(100)
  slug        String    @db.VarChar(100)
  description String?   @db.Text
  icon        String?   @db.VarChar(50)
  parentId    String?   @map("parent_id") @db.Uuid
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  
  // Core Audit Fields
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent     Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  businesses Business[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
  @@index([deletedAt])
  @@map("business_categories")
}

model Business {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  ownerId        String         @map("owner_id") @db.Uuid
  categoryId     String         @map("category_id") @db.Uuid
  entityId       String?        @unique @map("entity_id") @db.Uuid
  name           String         @db.VarChar(255)
  slug           String         @db.VarChar(255)
  description    String         @db.Text
  status         BusinessStatus @default(DRAFT)
  address        String         @db.Text
  city           String         @db.VarChar(100)
  state          String         @db.VarChar(100)
  zipCode        String         @map("zip_code") @db.VarChar(20)
  latitude       Decimal?       @db.Decimal(10, 8)
  longitude      Decimal?       @db.Decimal(11, 8)
  phone          String         @db.VarChar(50)
  email          String         @db.VarChar(255)
  website        String?        @db.Text
  ownerName      String?        @map("owner_name") @db.VarChar(255)
  district       String?        @db.VarChar(100)
  googleMapsUrl  String?        @map("google_maps_url") @db.Text
  socialLinks    Json           @default("{}") @map("social_links")
  tags           Json           @default("[]")
  subcategoryIds Json           @default("[]") @map("subcategory_ids")
  halalStatus    String?        @map("halal_status") @db.VarChar(20)
  profileType    BusinessProfileType @default(OWNER) @map("profile_type")
  logo           String?        @db.Text
  coverImage     String?        @map("cover_image") @db.Text
  operatingHours Json?          @map("operating_hours")
  averageRating  Decimal        @default(0) @map("average_rating") @db.Decimal(3, 2)
  totalReviews   Int            @default(0) @map("total_reviews")
  isVerified     Boolean        @default(false) @map("is_verified")
  verifiedAt     DateTime?      @map("verified_at")
  featuredUntil    DateTime?      @map("featured_until")
  parentBusinessId String?        @map("parent_business_id") @db.Uuid

  // Trial & Introductory Offer
  trialStatus             TrialStatus @default(NOT_STARTED) @map("trial_status")
  trialStartDate          DateTime?   @map("trial_start_date")
  trialEndDate            DateTime?   @map("trial_end_date")
  hasIntroOffer           Boolean     @default(false) @map("has_intro_offer")
  introOfferClaimedAt     DateTime?   @map("intro_offer_claimed_at")
  introOfferRedeemed      Boolean     @default(false) @map("intro_offer_redeemed")
  introOfferDiscountPct   Int         @default(20) @map("intro_offer_discount_pct")

  // Core Audit Fields
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")
  createdBy      String?        @map("created_by") @db.Uuid
  updatedBy      String?        @map("updated_by") @db.Uuid

  // Relations
  tenant            Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner             User                   @relation("BusinessOwner", fields: [ownerId], references: [id])
  category          Category               @relation(fields: [categoryId], references: [id])
  entity            Entity?                @relation(fields: [entityId], references: [id], onDelete: Cascade)
  branches          BusinessBranch[]
  documents         BusinessDocument[]
  staff             BusinessStaff[]
  verifications     BusinessVerification[]
  productCategories ProductCategory[]
  products          Product[]
  offers            Offer[]
  events            Event[]
  coupons           Coupon[]
  reviews           Review[]
  bookmarks         Bookmark[]
  favorites         Favorite[]
  media             Media[]
  metrics           BusinessMetric[]
  analyticsEvents   AnalyticsEvent[]
  verifiedPurchases VerifiedPurchase[]
  bills             Bill[]
  subscriptions     Subscription[]
  payments          Payment[]
  businessTags      BusinessTag[]
  customerRelationships BusinessCustomer[] @relation("BusinessCustomers")
  parentBusiness    Business?  @relation("BranchParent", fields: [parentBusinessId], references: [id])
  childBusinesses   Business[] @relation("BranchParent")

  @@unique([tenantId, slug])
  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([ownerId])
  @@index([categoryId])
  @@index([status])
  @@index([city, state])
  @@index([district])
  @@index([averageRating])
  @@index([deletedAt])
  @@map("businesses")
}

model BusinessTag {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  tag        String   @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([tenantId, businessId, tag])
  @@index([tenantId])
  @@index([businessId])
  @@index([tenantId, tag])
  @@map("business_tags")
}

// ── CUSTOMER-BUSINESS RELATIONSHIP ──────────────────────────

model BusinessCustomer {
  id                     String    @id @default(uuid()) @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  userId                 String    @map("user_id") @db.Uuid
  businessId             String    @map("business_id") @db.Uuid
  parentBusinessId       String?   @map("parent_business_id") @db.Uuid
  branchBusinessId       String?   @map("branch_business_id") @db.Uuid
  firstInteractionDate   DateTime  @default(now()) @map("first_interaction_date")
  lastInteractionDate    DateTime  @default(now()) @map("last_interaction_date")
  offersClaimedCount     Int       @default(0) @map("offers_claimed_count")
  offersRedeemedCount    Int       @default(0) @map("offers_redeemed_count")
  totalVerifiedPurchases Int       @default(0) @map("total_verified_purchases")
  referralSource         String?   @map("referral_source") @db.VarChar(100)
  customerStatus         String    @default("ACTIVE") @map("customer_status") @db.VarChar(50)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User     @relation("UserBusinessRelationships", fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation("BusinessCustomers", fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, businessId])
  @@index([tenantId, businessId])
  @@index([tenantId, userId])
  @@index([tenantId, businessId, customerStatus])
  @@index([lastInteractionDate])
  @@index([deletedAt])
  @@map("business_customers")
}

enum BusinessStatus {
  DRAFT
  PENDING_VERIFICATION
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  ARCHIVED
}

enum BusinessProfileType {
  OWNER
  AGENCY
  STAFF
}

enum TrialStatus {
  NOT_STARTED
  ACTIVE
  EXPIRED
  CONVERTED
}

model BusinessBranch {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  businessId      String    @map("business_id") @db.Uuid
  name            String    @db.VarChar(255)
  address         String    @db.Text
  city            String    @default("") @db.VarChar(100)
  state           String    @default("") @db.VarChar(100)
  zipCode         String    @default("") @map("zip_code") @db.VarChar(20)
  latitude        Decimal?  @db.Decimal(10, 8)
  longitude       Decimal?  @db.Decimal(11, 8)
  phone           String?   @db.VarChar(50)
  email           String?   @db.VarChar(255)
  managerName     String?   @map("manager_name") @db.VarChar(255)
  managerPhone    String?   @map("manager_phone") @db.VarChar(50)
  managerEmail    String?   @map("manager_email") @db.VarChar(255)
