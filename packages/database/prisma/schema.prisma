// ─── Analytics Aggregation Summary Tables ───────────────────────────────────
// Pre-aggregated summaries updated via event triggers.
// Dashboards read from these — never from transactional tables directly.

model UserSpendingSummary {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @unique @map("user_id") @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  totalSpend           Decimal   @default(0) @map("total_spend") @db.Decimal(14, 2)
  spendLast30Days      Decimal   @default(0) @map("spend_last_30_days") @db.Decimal(14, 2)
  spendLast90Days      Decimal   @default(0) @map("spend_last_90_days") @db.Decimal(14, 2)
  spendLast365Days     Decimal   @default(0) @map("spend_last_365_days") @db.Decimal(14, 2)
  verifiedBillCount    Int       @default(0) @map("verified_bill_count")
  offersClaimedCount   Int       @default(0) @map("offers_claimed_count")
  offersRedeemedCount  Int       @default(0) @map("offers_redeemed_count")
  primarySpendCategory String?   @map("primary_spend_category") @db.VarChar(100)
  engagementScore      Float     @default(0) @map("engagement_score")
  categoryBreakdown    Json      @default("{}") @map("category_breakdown")
  lastActivityAt       DateTime? @map("last_activity_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([tenantId, totalSpend])
  @@index([tenantId, engagementScore])
  @@map("user_spending_summaries")
}

model ReferralAnalyticsSummary {
