  billDate        DateTime   @map("bill_date")
  billImage       String     @map("bill_image") @db.Text
  status          BillStatus @default(UPLOADED)
  description     String?    @db.Text
  verifiedAt      DateTime?  @map("verified_at")
  verifiedBy      String?    @map("verified_by") @db.Uuid
  rejectionReason String?    @map("rejection_reason") @db.Text
  
  // Core Audit Fields
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")
  createdBy       String?    @map("created_by") @db.Uuid
  updatedBy       String?    @map("updated_by") @db.Uuid

  // Relations
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User               @relation("BillUploader", fields: [userId], references: [id])
  business         Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  verifier         User?              @relation("BillVerifier", fields: [verifiedBy], references: [id])
