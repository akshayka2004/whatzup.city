// ============================================================
// Prisma Schema — Enterprise SaaS Platform
// Multi-tenant architecture with tenant_id isolation
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── TENANTS ─────────────────────────────────────────────────

model Tenant {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  domain      String?  @db.VarChar(255)
  logo        String?  @db.Text
  settings    Json?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  users         User[]
  businesses    Business[]
  categories    Category[]
  announcements Announcement[]
  auditLogs     AuditLog[]

  @@map("tenants")
}

// ── USERS ───────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  email          String    @db.VarChar(255)
  passwordHash   String    @map("password_hash") @db.Text
  name           String    @db.VarChar(255)
  phone          String?   @db.VarChar(50)
  avatar         String?   @db.Text
  role           UserRole  @default(PUBLIC_USER)
  isActive       Boolean   @default(true) @map("is_active")
  emailVerified  Boolean   @default(false) @map("email_verified")
  lastLoginAt    DateTime? @map("last_login_at")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businesses      Business[]      @relation("BusinessOwner")
  reviews         Review[]
  bills           Bill[]          @relation("BillUploader")
  billsVerified   Bill[]          @relation("BillVerifier")
  notifications   Notification[]
  bookmarks       Bookmark[]
  sessions        Session[]
  reports         Report[]        @relation("ReportAuthor")
  reportsResolved Report[]        @relation("ReportResolver")
  auditLogs       AuditLog[]
  userRoles       UserPermission[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

enum UserRole {
  PUBLIC_USER
  BUSINESS_OWNER
  BUSINESS_STAFF
  GOVERNMENT_AGENCY
  ADMIN
  SUPER_ADMIN
}

// ── SESSIONS ────────────────────────────────────────────────

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @unique @map("refresh_token") @db.Text
  userAgent    String?  @map("user_agent") @db.Text
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

// ── PERMISSIONS ─────────────────────────────────────────────

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  resource    String   @db.VarChar(100)
  action      String   @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  userPermissions UserPermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserPermission {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  grantedAt    DateTime @default(now()) @map("granted_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

// ── CATEGORIES ──────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(100)
  slug        String   @db.VarChar(100)
  description String?  @db.Text
  icon        String?  @db.VarChar(50)
  parentId    String?  @map("parent_id") @db.Uuid
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent     Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  businesses Business[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
  @@map("categories")
}

// ── BUSINESSES ──────────────────────────────────────────────

model Business {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  ownerId         String         @map("owner_id") @db.Uuid
  categoryId      String         @map("category_id") @db.Uuid
  name            String         @db.VarChar(255)
  slug            String         @db.VarChar(255)
  description     String         @db.Text
  status          BusinessStatus @default(PENDING)
  address         String         @db.Text
  city            String         @db.VarChar(100)
  state           String         @db.VarChar(100)
  zipCode         String         @map("zip_code") @db.VarChar(20)
  latitude        Decimal?       @db.Decimal(10, 8)
  longitude       Decimal?       @db.Decimal(11, 8)
  phone           String         @db.VarChar(50)
  email           String         @db.VarChar(255)
  website         String?        @db.Text
  logo            String?        @db.Text
  coverImage      String?        @map("cover_image") @db.Text
  operatingHours  Json?          @map("operating_hours")
  averageRating   Decimal        @default(0) @map("average_rating") @db.Decimal(3, 2)
  totalReviews    Int            @default(0) @map("total_reviews")
  isVerified      Boolean        @default(false) @map("is_verified")
  verifiedAt      DateTime?      @map("verified_at")
  featuredUntil   DateTime?      @map("featured_until")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner     User      @relation("BusinessOwner", fields: [ownerId], references: [id])
  category  Category  @relation(fields: [categoryId], references: [id])
  branches  Branch[]
  products  Product[]
  offers    Offer[]
  reviews   Review[]
  bills     Bill[]
  media     Media[]
  bookmarks Bookmark[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([ownerId])
  @@index([categoryId])
  @@index([status])
  @@index([city, state])
  @@index([averageRating])
  @@index([deletedAt])
  @@map("businesses")
}

enum BusinessStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  ARCHIVED
}

// ── BRANCHES ────────────────────────────────────────────────

model Branch {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  name       String   @db.VarChar(255)
  address    String   @db.Text
  city       String   @db.VarChar(100)
  state      String   @db.VarChar(100)
  zipCode    String   @map("zip_code") @db.VarChar(20)
  latitude   Decimal? @db.Decimal(10, 8)
  longitude  Decimal? @db.Decimal(11, 8)
  phone      String?  @db.VarChar(50)
  email      String?  @db.VarChar(255)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("branches")
}

// ── PRODUCTS ────────────────────────────────────────────────

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @map("business_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String   @db.Text
  price       Decimal  @db.Decimal(12, 2)
  images      Json     @default("[]")
  isAvailable Boolean  @default(true) @map("is_available")
  sortOrder   Int      @default(0) @map("sort_order")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([isAvailable])
  @@index([deletedAt])
  @@map("products")
}

// ── OFFERS ──────────────────────────────────────────────────

model Offer {
  id                 String      @id @default(uuid()) @db.Uuid
  businessId         String      @map("business_id") @db.Uuid
  title              String      @db.VarChar(255)
  description        String      @db.Text
  discountPercent    Int?        @map("discount_percent")
  discountAmount     Decimal?    @map("discount_amount") @db.Decimal(12, 2)
  code               String?     @db.VarChar(50)
  status             OfferStatus @default(DRAFT)
  startDate          DateTime    @map("start_date")
  endDate            DateTime    @map("end_date")
  maxRedemptions     Int?        @map("max_redemptions")
  currentRedemptions Int         @default(0) @map("current_redemptions")
  terms              String?     @db.Text
  deletedAt          DateTime?   @map("deleted_at")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([deletedAt])
  @@map("offers")
}

enum OfferStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
  ARCHIVED
}

// ── REVIEWS ─────────────────────────────────────────────────

model Review {
  id                 String       @id @default(uuid()) @db.Uuid
  userId             String       @map("user_id") @db.Uuid
  businessId         String       @map("business_id") @db.Uuid
  rating             Int          @db.SmallInt
  title              String?      @db.VarChar(255)
  comment            String       @db.Text
  images             Json         @default("[]")
  status             ReviewStatus @default(PENDING)
  isVerifiedPurchase Boolean      @default(false) @map("is_verified_purchase")
  helpfulCount       Int          @default(0) @map("helpful_count")
  deletedAt          DateTime?    @map("deleted_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  // Relations
  user     User     @relation(fields: [userId], references: [id])
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([businessId])
  @@index([status])
  @@index([rating])
  @@index([deletedAt])
  @@map("reviews")
}

enum ReviewStatus {
  PENDING
  APPROVED
  FLAGGED
  REMOVED
}

// ── BILLS ───────────────────────────────────────────────────

model Bill {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  businessId  String     @map("business_id") @db.Uuid
  amount      Decimal    @db.Decimal(12, 2)
  billDate    DateTime   @map("bill_date")
  billImage   String     @map("bill_image") @db.Text
  status      BillStatus @default(UPLOADED)
  description String?    @db.Text
  verifiedAt  DateTime?  @map("verified_at")
  verifiedBy  String?    @map("verified_by") @db.Uuid
  rejectionReason String? @map("rejection_reason") @db.Text
  deletedAt   DateTime?  @map("deleted_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  // Relations
  user     User      @relation("BillUploader", fields: [userId], references: [id])
  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  verifier User?     @relation("BillVerifier", fields: [verifiedBy], references: [id])

  @@index([userId])
  @@index([businessId])
  @@index([status])
  @@index([deletedAt])
  @@map("bills")
}

enum BillStatus {
  UPLOADED
  PROCESSING
  VERIFIED
  REJECTED
  EXPIRED
}

// ── NOTIFICATIONS ───────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(255)
  body      String   @db.Text
  type      String   @db.VarChar(50)
  channel   String   @db.VarChar(50)
  isRead    Boolean  @default(false) @map("is_read")
  metadata  Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ── ANNOUNCEMENTS (Government) ──────────────────────────────

model Announcement {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  agencyId       String   @map("agency_id") @db.Uuid
  title          String   @db.VarChar(500)
  body           String   @db.Text
  category       String   @db.VarChar(100)
  priority       String   @default("MEDIUM") @db.VarChar(20)
  isPublished    Boolean  @default(false) @map("is_published")
  publishAt      DateTime? @map("publish_at")
  expiresAt      DateTime? @map("expires_at")
  targetAudience Json?    @map("target_audience")
  attachments    Json     @default("[]")
  viewCount      Int      @default(0) @map("view_count")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isPublished, publishAt])
  @@index([category])
  @@index([deletedAt])
  @@map("announcements")
}

// ── BOOKMARKS / FAVORITES ───────────────────────────────────

model Bookmark {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([userId])
  @@map("bookmarks")
}

// ── MEDIA ───────────────────────────────────────────────────

model Media {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  url        String   @db.Text
  type       String   @db.VarChar(20)
  filename   String   @db.VarChar(255)
  size       Int
  mimeType   String   @map("mime_type") @db.VarChar(100)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("media")
}

// ── REPORTS ─────────────────────────────────────────────────

model Report {
  id          String   @id @default(uuid()) @db.Uuid
  reporterId  String   @map("reporter_id") @db.Uuid
  targetType  String   @map("target_type") @db.VarChar(50)
  targetId    String   @map("target_id") @db.Uuid
  type        String   @db.VarChar(50)
  status      String   @default("PENDING") @db.VarChar(50)
  description String   @db.Text
  evidence    Json     @default("[]")
  resolution  String?  @db.Text
  resolvedBy  String?  @map("resolved_by") @db.Uuid
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  reporter User  @relation("ReportAuthor", fields: [reporterId], references: [id])
  resolver User? @relation("ReportResolver", fields: [resolvedBy], references: [id])

  @@index([reporterId])
  @@index([targetType, targetId])
  @@index([status])
  @@map("reports")
}

// ── ANALYTICS EVENTS ────────────────────────────────────────

model AnalyticsEvent {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  businessId String?  @map("business_id") @db.Uuid
  event      String   @db.VarChar(100)
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.Text
  sessionId  String?  @map("session_id") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([businessId])
  @@index([event])
  @@index([createdAt])
  @@map("analytics_events")
}

// ── AUDIT LOGS ──────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar(50)
  resource   String   @db.VarChar(100)
  resourceId String?  @map("resource_id") @db.Uuid
  oldData    Json?    @map("old_data")
  newData    Json?    @map("new_data")
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── FEATURE FLAGS ───────────────────────────────────────────

model FeatureFlag {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(100)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  isEnabled   Boolean  @default(false) @map("is_enabled")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}
