# ============================================================
# Enterprise SaaS Platform — Environment Configuration
# ============================================================

# ── General ──────────────────────────────────────────────────
NODE_ENV=development
APP_NAME="SaaS Platform"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas_platform?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_TTL=3600

# ── JWT / Authentication ─────────────────────────────────────
JWT_SECRET="change-me-to-a-random-64-char-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-to-another-random-64-char-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ── File Storage (Cloudflare R2) ─────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="saas-uploads"
R2_PUBLIC_URL=""

# ── Search (Typesense) ──────────────────────────────────────
TYPESENSE_HOST="localhost"
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=""
TYPESENSE_PROTOCOL="http"

# ── Notifications ────────────────────────────────────────────
# Firebase Cloud Messaging
FCM_PROJECT_ID=""
FCM_PRIVATE_KEY=""
FCM_CLIENT_EMAIL=""

# Email (SMTP)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@saasplatform.com"

# ── Rate Limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
