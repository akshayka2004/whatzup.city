# ============================================================
# Enterprise SaaS Platform — Production Environment
# Customized for Current Deployment
# ============================================================

# ============================================================
# GENERAL
# ============================================================

NODE_ENV=production

APP_NAME=SaaS Platform

DOMAIN=72.61.238.98

APP_URL=http://72.61.238.98
FRONTEND_URL=http://72.61.238.98

# API_URL is read by Next.js /api proxy at runtime — use localhost (same VPS, port 4001)
API_URL=http://localhost:4001

NEXT_PUBLIC_FRONTEND_URL=http://72.61.238.98
# IMPORTANT: Leave NEXT_PUBLIC_API_URL EMPTY for bare-metal HTTP deployment.
# The browser must use same-origin /api requests so Next.js can proxy them.
# Setting an absolute URL here bakes it into the JS bundle and causes CORS failures.
NEXT_PUBLIC_API_URL=

TRUST_PROXY=true

# ============================================================
# DATABASE — SUPABASE POSTGRESQL
# ============================================================

DATABASE_URL=postgresql://postgres.zavtnuywvpwchmdqndli:lifeArt%402026@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

DIRECT_URL=postgresql://postgres.zavtnuywvpwchmdqndli:lifeArt%402026@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

DATABASE_POOL_MIN=4
DATABASE_POOL_MAX=20

PRISMA_CONNECTION_LIMIT=20
PRISMA_POOL_TIMEOUT=30
PRISMA_ENABLE_LOGGING=false

# ============================================================
# REDIS
# ============================================================

REDIS_HOST=redis
REDIS_PORT=6379

REDIS_PASSWORD=RedisStrongPassword123

REDIS_URL=redis://:RedisStrongPassword123@redis:6379

REDIS_TTL=3600

REDIS_MAX_RETRIES=10
REDIS_CONNECT_TIMEOUT=10000
REDIS_LAZY_CONNECT=true

# ============================================================
# JWT / AUTHENTICATION
# ============================================================

JWT_SECRET=Qx9L2mV7pR4tY8uK1nF6cD3wS5jH0zXaB9eT2gWpM7yU

JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=Zr8Np4Kx1Vm7Qw2Ty9Hd5Ls3Bc6Ju0FaE4Ri8MoPq2X

JWT_REFRESH_EXPIRES_IN=7d

SESSION_ROTATION_ENABLED=true
REFRESH_TOKEN_REUSE_DETECTION=true

# ============================================================
# COOKIE SECURITY
# ============================================================

COOKIE_DOMAIN=72.61.238.98

COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax

# ============================================================
# CORS
# ============================================================

CORS_ORIGINS=http://72.61.238.98,http://72.61.238.98:3000,http://72.61.238.98:3001

# ============================================================
# SUPABASE
# ============================================================

SUPABASE_URL=https://zavtnuywvpwchmdqndli.supabase.co

SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_YOUR_SUPABASE_SERVICE_ROLE_KEY

NEXT_PUBLIC_SUPABASE_URL=https://zavtnuywvpwchmdqndli.supabase.co

NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_7guQ4_YIzcLnorsenLu_MQ_u07kKDPf

# ============================================================
# SUPABASE STORAGE
# ============================================================

STORAGE_PROVIDER=supabase

SUPABASE_STORAGE_BUCKET=saas-uploads

NEXT_PUBLIC_SUPABASE_BUCKET=saas-uploads

STORAGE_MAX_PARALLEL_UPLOADS=5

SIGNED_UPLOAD_URL_EXPIRY=300

# ============================================================
# FILE UPLOAD SECURITY
# ============================================================

MAX_FILE_UPLOAD_SIZE=10485760

ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ============================================================
# OCR PROCESSING
# ============================================================

OCR_MAX_FILE_SIZE=5242880

OCR_ALLOWED_TYPES=image/jpeg,image/png,application/pdf

OCR_QUEUE_CONCURRENCY=5

# ============================================================
# TYPESENSE
# ============================================================

TYPESENSE_HOST=typesense

TYPESENSE_PORT=8108

TYPESENSE_PROTOCOL=http

TYPESENSE_API_KEY=Ty9Lp4Qw7Er2Nk8Vm5Xs1Da6Bc3Hu0Rt

TYPESENSE_TIMEOUT_SECONDS=10

TYPESENSE_BATCH_SIZE=100

# ============================================================
# SMTP / EMAIL
# ============================================================

SMTP_HOST=smtp.sendgrid.net

SMTP_PORT=587

SMTP_USER=apikey

SMTP_PASS=REPLACE_WITH_SENDGRID_API_KEY

SMTP_FROM=noreply@saasplatform.com

# ============================================================
# RATE LIMITING
# ============================================================

THROTTLE_TTL=60

THROTTLE_LIMIT=100

THROTTLE_BURST_LIMIT=20

# ============================================================
# LOGGING
# ============================================================

LOG_LEVEL=info

LOG_PRETTY=false

LOG_REQUESTS=true

# ============================================================
# HEALTHCHECKS
# ============================================================

HEALTHCHECK_TIMEOUT=10

HEALTHCHECK_INTERVAL=30

HEALTHCHECK_RETRIES=5

# ============================================================
# NGINX
# ============================================================

NGINX_SET_REAL_IP_FROM=0.0.0.0/0

# ============================================================
# ANALYTICS
# ============================================================

ANALYTICS_RETENTION_DAYS=365

AUDIT_LOG_RETENTION_DAYS=180

# ============================================================
# SUPPORT SYSTEM
# ============================================================

SUPPORT_AUTO_ASSIGN=true

SUPPORT_ESCALATION_HOURS=24

# ============================================================
# OFFER AUTOMATION
# ============================================================

OFFER_EXPIRY_CRON=*/30 * * * *

# ============================================================
# BILL / MODERATION PROCESSING
# ============================================================

BILL_VERIFICATION_ENABLED=true

AUTO_MODERATION_ENABLED=true

# ============================================================
# SECURITY
# ============================================================

ENABLE_SECURITY_HEADERS=true

ENABLE_RATE_LIMITING=true

ENABLE_CSRF_PROTECTION=true

ENABLE_AUDIT_LOGGING=true

# ============================================================
# FEATURE FLAGS
# ============================================================

ENABLE_ANALYTICS=true

ENABLE_OCR=true

ENABLE_NOTIFICATIONS=true

ENABLE_SUPPORT_SYSTEM=true

ENABLE_BRANCH_ANALYTICS=true

ENABLE_SUBSCRIPTIONS=true

ENABLE_CUSTOM_FIELDS=true

ENABLE_DYNAMIC_SOCIAL_FIELDS=true